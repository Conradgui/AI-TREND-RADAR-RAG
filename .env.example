# LLM provider for local scripts.
# Copy this file to .env and fill only the provider you use.

# DeepSeek
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
# Set this to the exact model ID enabled for your account if different.
# DEEPSEEK_MODEL=deepseek-chat

# Output controls
# REPORT_LANGS=zh
# SAVE_SOURCE_REPORTS=0

# GitHub is recommended for higher rate limits and issue creation.
# GITHUB_TOKEN=your_github_token

# Optional sources / notifications
# PRODUCTHUNT_TOKEN=your_producthunt_token
# GITEE_TOKEN=your_gitee_token
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
# FEISHU_WEBHOOK_URLS=your_feishu_webhook_url

# Other supported LLM providers
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxx
